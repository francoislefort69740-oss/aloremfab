<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".fragment.RegistrationFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:backgroundTint="@color/background"
        tools:context=".activity.MainActivity">

        <ImageView
            android:id="@+id/imageView_ALOREM_registration"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:src="@drawable/full_logo_alorem"
            app:layout_constraintDimensionRatio="3:1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/menu_guideline_3_registration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.38"/>

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/menu_guideline_1_registration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.78"/>

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/menu_guideline_2_registration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.88"/>

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/menu_guideline_4_registration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.12"/>

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/menu_guideline_5_registration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.06"/>

        <Button
            android:id="@+id/newUser_registration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/primary_color"
            android:padding="20dp"
            android:text="@string/nouveau_utilisateur_registration"
            app:layout_constraintBottom_toTopOf="@+id/menu_guideline_2_registration"
            app:layout_constraintStart_toStartOf="@+id/menu_guideline_5_registration" />

        <Button
            android:id="@+id/updateUser_menu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/primary_color"
            android:padding="10dp"
            android:text="@string/mettre_a_jour_registration"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/usertitleactivated_registration"
            app:layout_constraintTop_toTopOf="@+id/usertitleactivated_registration" />

        <TextView
            android:id="@+id/usertitleactivated_registration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/utilisateur_actif_registration"
            android:textSize="30sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@+id/nameTitle_registration"
            app:layout_constraintStart_toStartOf="@+id/menu_guideline_4_registration"
            app:layout_constraintTop_toBottomOf="@+id/imageView_ALOREM_registration" />

        <TextView
            android:id="@+id/nameTitle_registration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nom_menu"
            android:textAlignment="center"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@+id/forenameTitle_registration"
            app:layout_constraintStart_toStartOf="@+id/menu_guideline_4_registration"
            app:layout_constraintTop_toBottomOf="@+id/usertitleactivated_registration" />


        <TextView
            android:id="@+id/forenameTitle_registration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/prenom_menu"
            android:textAlignment="center"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@+id/emailTitle_registration"
            app:layout_constraintStart_toStartOf="@+id/nameTitle_registration"
            app:layout_constraintTop_toBottomOf="@+id/nameTitle_registration" />

        <TextView
            android:id="@+id/emailTitle_registration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/email_menu"
            android:textAlignment="center"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@+id/menu_guideline_3_registration"
            app:layout_constraintStart_toStartOf="@+id/nameTitle_registration"
            app:layout_constraintTop_toBottomOf="@+id/forenameTitle_registration" />


        <TextView
            android:id="@+id/nameMenu_registration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:textAlignment="center"
            android:textSize="20sp"
            app:layout_constraintStart_toEndOf="@+id/forenameTitle_registration"
            app:layout_constraintTop_toTopOf="@+id/nameTitle_registration" />

        <TextView
            android:id="@+id/forenameMenu_registration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:textSize="20sp"
            app:layout_constraintStart_toStartOf="@+id/nameMenu_registration"
            app:layout_constraintTop_toTopOf="@+id/forenameTitle_registration" />

        <TextView
            android:id="@+id/emailMenu_menu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:textSize="20sp"
            app:layout_constraintStart_toStartOf="@+id/forenameMenu_registration"
            app:layout_constraintTop_toTopOf="@+id/emailTitle_registration" />



        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/registration_exit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            android:backgroundTint="@color/primary_700"
            android:src="@drawable/ic_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:tint="@android:color/white" />


    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
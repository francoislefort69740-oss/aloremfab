<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Item not activated -->
    <item android:state_activated="false">
        <shape >
            <corners android:radius="12dp" />
            <gradient
                android:startColor="@color/light_grey"
                android:endColor="@color/medium_grey"
                android:angle="135"/>
            <stroke android:width="2dp" android:color="@color/dark_grey" />
        </shape>
    </item>

    <!-- Item activated -->
    <item android:state_activated="true">
        <shape >
            <corners android:radius="12dp" />
            <gradient
                android:startColor="@color/primary_100"
                android:endColor="@color/primary_500"
                android:angle="135"/>
            <stroke android:width="2dp" android:color="@color/primary_700" />
        </shape>
    </item>


</selector>
